# Environment file for autossh reverse tunnel (Pi -> VDS)
# Copy to /etc/shectory/autossh-tunnel.env on Pi and fill in values.
# Permissions: chmod 600 /etc/shectory/autossh-tunnel.env

# VDS SSH connection
TUNNEL_HOST=shectory.ru
TUNNEL_USER=shectory
TUNNEL_SSH_PORT=2222
TUNNEL_SSH_KEY=/home/pi/.ssh/id_ed25519_tunnel

# Remote ports on VDS (127.0.0.1) that will forward to Pi's local ports
TUNNEL_SYSLOG_PORT=24444
TUNNEL_PINGMASTER_PORT=24555
TUNNEL_SSH_RPORT=22022
