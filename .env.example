# Скопируйте в .env в корне репозитория и/или в shectory-portal/.env (для Next.js).
# Не коммитить файл с секретами.

# PostgreSQL — per-project БД/роль (см. docs/prisma-cursorrpa.md)
# Формат: postgresql://project_<slug>_app:<password>@HOST:5432/project_<slug>?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Опционально: путь workspace портала для seed (мета-проект shectory-portal)
# SHECTORY_PORTAL_WORKSPACE_PATH=/home/shectory/workspaces/CursorRPA/shectory-portal

# Cursor Agent CLI (портал): таймауты и оркестратор тикета (анализ → 3 подзадачи → итог, 5 шагов)
# AGENT_PROMPT_TIMEOUT_MS=1800000
# AGENT_ORCHESTRATOR_PHASE_TIMEOUT_MS=
# AGENT_ORCHESTRATOR_CONTEXT_TRIM=12000
# AGENT_ORCHESTRATOR_HEARTBEAT_SEC=45
