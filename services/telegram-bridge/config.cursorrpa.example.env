# Шаблон для пользователя cursorrpa на dev-rpa: скопировать в .env и заполнить токен.
#   cp config.cursorrpa.example.env .env && nano .env && chmod 600 .env

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

CURSOR_RPA_FIXED_WORKSPACE=/home/cursorrpa/workspaces/pilot
WORKSPACE_ROOT=/home/cursorrpa/workspaces

RPA_AGENT_SCRIPT=/home/cursorrpa/.local/bin/rpa-agent.sh
CURSOR_ENV_FILE=/home/cursorrpa/.config/cursor-rpa/env.sh

AGENT_TIMEOUT_SEC=900

# Привет админам при старте (можно заменить на одно слово: TELEGRAM_STARTUP_MESSAGE=Привет)
# TELEGRAM_STARTUP_MESSAGE=
