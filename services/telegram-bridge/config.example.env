# Скопируйте в .env на сервере (не коммитить).

# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Через запятую числовые Telegram user id (только эти пользователи могут ботом пользоваться).
# Узнать id: написать @userinfobot или включить логирование update.effective_user.id
TELEGRAM_ALLOWED_USER_IDS=

# Режим пилота: один бот = один проект — абсолютный путь (тогда /project не нужен)
# CURSOR_RPA_FIXED_WORKSPACE=/home/shevbo/workspaces/myapp

# Корень workspace: подпапки по имени из /project (если FIXED_WORKSPACE не задан)
WORKSPACE_ROOT=/home/shevbo/workspaces

# Скрипт RPA (на сервере после деплоя)
RPA_AGENT_SCRIPT=/home/shevbo/.local/bin/rpa-agent.sh

# Ключ Cursor (если не подключаете через ~/.bashrc при запуске systemd — задайте здесь)
# CURSOR_API_KEY=

# Файл с export CURSOR_API_KEY=... (предпочтительно для systemd)
CURSOR_ENV_FILE=/home/shevbo/.config/cursor-rpa/env.sh

# Опционально: команда деплоя UI на VDS (bash -c). Доступны env: WORKSPACE, PROJECT_NAME
# Пример: rsync -az "$WORKSPACE/web/dist/" user@VDS:/var/www/proto/
# DEPLOY_UI_SCRIPT=

# Опционально: сборка APK после MVP (bash -c), те же env
# BUILD_APK_SCRIPT=

# Таймаут одного вызова агента (секунды)
AGENT_TIMEOUT_SEC=900

# Макс. длина одного сообщения ТГ (запас под заголовок «часть N/M»)
# TELEGRAM_MESSAGE_MAX_CHARS=4000

# Интервал «печатает…» (секунды), пока идёт агент
# TELEGRAM_TYPING_INTERVAL_SEC=4.5
