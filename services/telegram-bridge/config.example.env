# Скопируйте в .env на сервере (не коммитить).

# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Через запятую числовые Telegram user id (только эти пользователи могут ботом пользоваться).
# Узнать id: написать @userinfobot или включить логирование update.effective_user.id
TELEGRAM_ALLOWED_USER_IDS=

# Режим пилота: один бот = один проект — абсолютный путь (тогда /project не нужен)
# CURSOR_RPA_FIXED_WORKSPACE=/home/shevbo/workspaces/myapp

# Корень workspace: подпапки по имени из /project (если FIXED_WORKSPACE не задан)
WORKSPACE_ROOT=/home/shevbo/workspaces

# Скрипт RPA (на сервере после деплоя)
RPA_AGENT_SCRIPT=/home/shevbo/.local/bin/rpa-agent.sh

# Ключ Cursor (если не подключаете через ~/.bashrc при запуске systemd — задайте здесь)
# CURSOR_API_KEY=

# Файл с export CURSOR_API_KEY=... (предпочтительно для systemd)
CURSOR_ENV_FILE=/home/shevbo/.config/cursor-rpa/env.sh

# Опционально: команда деплоя UI на VDS (bash -c). Доступны env: WORKSPACE, PROJECT_NAME
# Пример: rsync -az "$WORKSPACE/web/dist/" user@VDS:/var/www/proto/
# DEPLOY_UI_SCRIPT=

# Опционально: сборка APK после MVP (bash -c), те же env
# BUILD_APK_SCRIPT=

# Таймаут одного вызова агента (секунды)
AGENT_TIMEOUT_SEC=900

# Макс. длина одного сообщения ТГ (запас под заголовок «часть N/M»)
# TELEGRAM_MESSAGE_MAX_CHARS=4000

# Текст приветствия админам (TELEGRAM_ALLOWED_USER_IDS) при каждом старте бота. Пусто = не слать.
# TELEGRAM_STARTUP_MESSAGE=Привет! Бот запущен.

# Интервал «печатает…» (секунды), пока идёт агент
# TELEGRAM_TYPING_INTERVAL_SEC=4.5

# --- Health checks (hoster / shectory / pi) ---
# Проверка снимков каждые 5 минут (по умолчанию 300). Рекомендуется не делать чаще, чтобы не долбить ssh/диск.
# HEALTH_CHECK_INTERVAL_SEC=300
# Регулярный отчёт админам каждые 5 минут (по умолчанию 300).
# HEALTH_REPORT_INTERVAL_SEC=300

# --- Монитор Raspberry Pi (Syslog / Pingmaster) для CursorRPA Telegram ---
# Задайте хост или IP, куда с машины бота доступны TCP-порты. Раз в PI_MONITOR_INTERVAL_SEC (по умолчанию 300 с)
# админам (TELEGRAM_ALLOWED_USER_IDS) уходит отчёт: ресурсы Pi (если задан SSH), порты Syslog и Pingmaster.
# PI_MONITOR_HOST=192.168.1.50
# # Несколько хостов (на каждом проверяются ОБА порта ниже — типично IP Pi в LAN):
# PI_MONITOR_HOSTS=192.168.1.105
# PI_SYSLOG_PORT=4444
# PI_PINGMASTER_PORT=4555
# # Публичные URL для пользователей: https://syslog.shectory.ru и https://pingmaster.shectory.ru
# # (этот TCP-монитор — не HTTPS-чек поддоменов; для внешней смотримость используйте health портала или curl).
# PI_MONITOR_INTERVAL_SEC=300
# # Отчёт раз в час:
# PI_MONITOR_REPORT_INTERVAL_SEC=3600
# # Полная команда ssh до удалённого шелла, без кавычек в конце. Пример:
# # PI_MONITOR_SSH=ssh -o BatchMode=yes -o ConnectTimeout=5 pi@raspberrypi.local
# PI_MONITOR_SSH=
# # Ключ только для портала (systemd без ssh-agent): см. scripts/shectory-portal-pi-ssh.example.conf
# PI_MONITOR_IDENTITY_FILE=/home/you/.ssh/id_ed25519_pi
# PI_MONITOR_TCP_TIMEOUT=3
# PI_MONITOR_SSH_TIMEOUT_SEC=12
